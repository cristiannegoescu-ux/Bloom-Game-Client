{
  "name": "bloom-game-client",
  "version": "1.0.0",
  "description": "Bloom Game Client — Bloomberg defect simulation demo",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ubisoft.bloom-game-client",
    "productName": "Bloom Game Client",
    "win": {
      "target": "nsis",
      "icon": "assets/game.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false
    },
    "files": ["src/**/*", "assets/**/*"]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
